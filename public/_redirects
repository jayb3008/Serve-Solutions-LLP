# ── SPA Routing
# Specific sub-apps or paths first
/admin/*    /index.html   200

# Main SPA catch-all
# This ensures that when you refresh a page like /portfolio/123, 
# the server serves index.html and let React Router handle the path.
/*          /index.html   200

